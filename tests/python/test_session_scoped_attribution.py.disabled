"""
Tests for Phase 3: session-scoped active work item attribution in hooks.

Verifies that prompt_analyzer.py and event_tracker.py resolve feature attribution
from the sessions table (active_feature_id column) rather than global HTML scans.

Test coverage:
1. get_active_work_item(context) returns session-specific item when active_feature_id is set
2. _get_active_feature_id(context) returns session-specific ID
3. Falls back to global scan when context has no session_id (or session_id == "unknown")
4. Falls back to global scan when active_feature_id is NULL in sessions table
5. event_tracker resolve path uses session row before glob fallback
"""

from pathlib import Path
from typing import Any
from unittest.mock import MagicMock, patch
from uuid import uuid4

from htmlgraph.db.schema import HtmlGraphDB
from htmlgraph.hooks.prompt_analyzer import (
    _get_active_feature_id,
    get_active_work_item,
)

# ---------------------------------------------------------------------------
# Helpers / Fixtures
# ---------------------------------------------------------------------------


def _make_db(tmp_path: Path, suffix: str = "") -> HtmlGraphDB:
    db_path = str(tmp_path / f"test_{suffix or uuid4().hex}.db")
    db = HtmlGraphDB(db_path)
    return db


def _insert_session(db: HtmlGraphDB, session_id: str) -> None:
    db.insert_session(session_id=session_id, agent_assigned="test-agent")


def _insert_feature(
    db: HtmlGraphDB, feature_id: str, title: str = "Test Feature"
) -> None:
    """Insert a minimal row into the features table."""
    db.connection.cursor().execute(
        """
        INSERT OR IGNORE INTO features (id, title, status, type)
        VALUES (?, ?, 'in-progress', 'feature')
        """,
        (feature_id, title),
    )
    db.connection.commit()


def _make_context(
    session_id: str,
    db: HtmlGraphDB,
    graph_dir: Path | None = None,
) -> Any:
    """Build a minimal HookContext-like mock with a real DB attached."""
    ctx = MagicMock()
    ctx.session_id = session_id
    ctx.graph_dir = graph_dir or Path("/tmp/fake-graph-dir")
    # Attach the real DB so context.database returns it
    ctx.database = db
    return ctx


# ---------------------------------------------------------------------------
# get_active_work_item — session-scoped primary path
# ---------------------------------------------------------------------------


class TestGetActiveWorkItemSessionScoped:
    """get_active_work_item() should use session row as primary source."""

    def test_returns_work_item_dict_from_session_row(self, tmp_path):
        """When sessions.active_feature_id is set, return a full dict."""
        db = _make_db(tmp_path, "gawi_session")
        session_id = "sess-gawi-01"
        feature_id = "feat-gawi-01"

        _insert_session(db, session_id)
        _insert_feature(db, feature_id, "My Active Feature")
        db.set_active_work_item(session_id, feature_id)

        # Point get_session_active_item_id at the right DB file
        import shutil

        shutil.copy(db.db_path, str(tmp_path / "htmlgraph.db"))
        ctx = _make_context(session_id, db, tmp_path)

        result = get_active_work_item(ctx)

        assert result is not None
        assert result["id"] == feature_id
        assert result["title"] == "My Active Feature"
        assert result["status"] == "in-progress"
        assert result["type"] == "feature"
        db.disconnect()

    def test_returns_minimal_dict_when_feature_not_in_features_table(self, tmp_path):
        """If the feature ID is set but not in features table, return minimal dict."""
        db = _make_db(tmp_path, "gawi_minimal")
        session_id = "sess-gawi-min-01"
        feature_id = "feat-unknown-xyz"

        _insert_session(db, session_id)
        db.set_active_work_item(session_id, feature_id)

        import shutil

        shutil.copy(db.db_path, str(tmp_path / "htmlgraph.db"))
        ctx = _make_context(session_id, db, tmp_path)

        result = get_active_work_item(ctx)

        assert result is not None
        assert result["id"] == feature_id
        assert result["status"] == "in-progress"
        db.disconnect()

    def test_falls_back_to_sdk_when_session_has_no_active_item(self, tmp_path):
        """When active_feature_id is NULL, fall back to SDK global scan."""
        db = _make_db(tmp_path, "gawi_fallback")
        session_id = "sess-gawi-fb-01"
        _insert_session(db, session_id)

        import shutil

        shutil.copy(db.db_path, str(tmp_path / "htmlgraph.db"))
        ctx = _make_context(session_id, db, tmp_path)

        sdk_item = {"id": "feat-sdk-global", "title": "SDK Item", "type": "feature"}
        with patch("htmlgraph.hooks.prompt_analyzer.SDK") as mock_sdk_cls:
            mock_sdk = MagicMock()
            mock_sdk.get_active_work_item.return_value = sdk_item
            mock_sdk_cls.return_value = mock_sdk

            result = get_active_work_item(ctx)

        assert result is not None
        assert result["id"] == "feat-sdk-global"
        db.disconnect()

    def test_falls_back_to_sdk_when_session_id_is_unknown(self, tmp_path):
        """When session_id is 'unknown', skip session lookup and fall back to SDK."""
        db = _make_db(tmp_path, "gawi_unknown")
        ctx = _make_context("unknown", db, tmp_path)

        sdk_item = {"id": "feat-fallback-sdk", "title": "SDK Fallback"}
        with patch("htmlgraph.hooks.prompt_analyzer.SDK") as mock_sdk_cls:
            mock_sdk = MagicMock()
            mock_sdk.get_active_work_item.return_value = sdk_item
            mock_sdk_cls.return_value = mock_sdk

            result = get_active_work_item(ctx)

        assert result is not None
        assert result["id"] == "feat-fallback-sdk"
        db.disconnect()

    def test_returns_none_when_both_session_and_sdk_have_nothing(self, tmp_path):
        """When neither session row nor SDK have an active item, return None."""
        db = _make_db(tmp_path, "gawi_none")
        session_id = "sess-gawi-none-01"
        _insert_session(db, session_id)

        import shutil

        shutil.copy(db.db_path, str(tmp_path / "htmlgraph.db"))
        ctx = _make_context(session_id, db, tmp_path)

        with patch("htmlgraph.hooks.prompt_analyzer.SDK") as mock_sdk_cls:
            mock_sdk = MagicMock()
            mock_sdk.get_active_work_item.return_value = None
            mock_sdk_cls.return_value = mock_sdk

            result = get_active_work_item(ctx)

        assert result is None
        db.disconnect()


# ---------------------------------------------------------------------------
# _get_active_feature_id — session-scoped primary path
# ---------------------------------------------------------------------------


class TestGetActiveFeatureIdSessionScoped:
    """_get_active_feature_id() should use session row when context is provided."""

    def test_returns_id_from_session_row(self, tmp_path):
        db = _make_db(tmp_path, "gafi_session")
        session_id = "sess-gafi-01"
        feature_id = "feat-gafi-01"

        _insert_session(db, session_id)
        db.set_active_work_item(session_id, feature_id)

        import shutil

        shutil.copy(db.db_path, str(tmp_path / "htmlgraph.db"))
        ctx = _make_context(session_id, db, tmp_path)

        result = _get_active_feature_id(ctx)
        assert result == feature_id
        db.disconnect()

    def test_falls_back_to_sdk_when_session_has_no_item(self, tmp_path):
        db = _make_db(tmp_path, "gafi_fallback")
        session_id = "sess-gafi-fb-01"
        _insert_session(db, session_id)

        import shutil

        shutil.copy(db.db_path, str(tmp_path / "htmlgraph.db"))
        ctx = _make_context(session_id, db, tmp_path)

        with patch("htmlgraph.hooks.prompt_analyzer.SDK") as mock_sdk_cls:
            mock_sdk = MagicMock()
            mock_sdk.get_active_work_item.return_value = {"id": "feat-sdk-fb"}
            mock_sdk_cls.return_value = mock_sdk

            result = _get_active_feature_id(ctx)

        assert result == "feat-sdk-fb"
        db.disconnect()

    def test_falls_back_to_sdk_when_no_context(self):
        """Without a context, should fall back to global SDK scan."""
        with patch("htmlgraph.hooks.prompt_analyzer.SDK") as mock_sdk_cls:
            mock_sdk = MagicMock()
            mock_sdk.get_active_work_item.return_value = {"id": "feat-nocontext"}
            mock_sdk_cls.return_value = mock_sdk

            result = _get_active_feature_id(None)

        assert result == "feat-nocontext"

    def test_returns_none_when_no_context_and_sdk_has_nothing(self):
        with patch("htmlgraph.hooks.prompt_analyzer.SDK") as mock_sdk_cls:
            mock_sdk = MagicMock()
            mock_sdk.get_active_work_item.return_value = None
            mock_sdk_cls.return_value = mock_sdk

            result = _get_active_feature_id(None)

        assert result is None


# ---------------------------------------------------------------------------
# event_tracker: session-scoped resolution precedes glob scan
# ---------------------------------------------------------------------------


class TestEventTrackerSessionScopedResolution:
    """
    Verify that the event_tracker.py fallback resolution uses session row
    before falling back to the glob scan of HTML files.
    """

    def test_session_row_used_before_glob_scan(self, tmp_path):
        """
        When db.get_active_work_item_for_session returns a value, the glob
        scan should NOT be reached.
        """
        feature_id = "feat-tracker-session"
        session_id = "sess-tracker-01"

        db = _make_db(tmp_path, "tracker_session")
        _insert_session(db, session_id)
        db.set_active_work_item(session_id, feature_id)

        # Verify: db.get_active_work_item_for_session returns the value
        result = db.get_active_work_item_for_session(session_id)
        assert result == feature_id

        # Glob directory is empty — if glob were called, it would return nothing
        glob_dir = tmp_path / "bugs"
        glob_dir.mkdir()
        assert not list(glob_dir.glob("bug-*.html"))

        # Simulate the resolution logic from event_tracker.py
        resolved_feature_id = None

        # Fallback 1: session-scoped lookup (primary path)
        if not resolved_feature_id and session_id and db:
            try:
                resolved_feature_id = db.get_active_work_item_for_session(session_id)
            except Exception:
                pass

        # Glob scan should NOT have been needed
        assert resolved_feature_id == feature_id
        db.disconnect()

    def test_glob_scan_used_when_session_row_empty(self, tmp_path):
        """
        When db.get_active_work_item_for_session returns None, the glob
        scan of HTML files should be attempted as last resort.
        """
        session_id = "sess-tracker-glob"
        db = _make_db(tmp_path, "tracker_glob")
        _insert_session(db, session_id)
        # No active item set in session row

        graph_dir = tmp_path
        bugs_dir = graph_dir / "bugs"
        bugs_dir.mkdir()

        # Create a fake in-progress HTML bug file
        bug_file = bugs_dir / "bug-abc123.html"
        bug_file.write_text('<div data-status="in-progress">Bug</div>')

        resolved_feature_id = None

        # Fallback 1: session-scoped (returns None)
        if not resolved_feature_id and session_id and db:
            try:
                resolved_feature_id = db.get_active_work_item_for_session(session_id)
            except Exception:
                pass

        # Fallback 2: glob scan (legacy)
        if not resolved_feature_id and graph_dir:
            try:
                gd = Path(str(graph_dir))
                for subdir, prefix in [
                    ("bugs", "bug-"),
                    ("spikes", "spk-"),
                    ("features", "spk-"),
                ]:
                    search = gd / subdir
                    if not search.exists():
                        continue
                    for html_file in search.glob(f"{prefix}*.html"):
                        content = html_file.read_text(errors="ignore")
                        if 'data-status="in-progress"' in content:
                            resolved_feature_id = html_file.stem
                            break
                    if resolved_feature_id:
                        break
            except Exception:
                pass

        assert resolved_feature_id == "bug-abc123"
        db.disconnect()

    def test_no_resolution_when_both_session_and_glob_empty(self, tmp_path):
        """When neither session row nor HTML files yield a result, stays None."""
        session_id = "sess-tracker-none"
        db = _make_db(tmp_path, "tracker_none")
        _insert_session(db, session_id)

        graph_dir = tmp_path
        resolved_feature_id = None

        if not resolved_feature_id and session_id and db:
            try:
                resolved_feature_id = db.get_active_work_item_for_session(session_id)
            except Exception:
                pass

        if not resolved_feature_id and graph_dir:
            try:
                gd = Path(str(graph_dir))
                for subdir, prefix in [("bugs", "bug-"), ("spikes", "spk-")]:
                    search = gd / subdir
                    if not search.exists():
                        continue
                    for html_file in search.glob(f"{prefix}*.html"):
                        content = html_file.read_text(errors="ignore")
                        if 'data-status="in-progress"' in content:
                            resolved_feature_id = html_file.stem
                            break
                    if resolved_feature_id:
                        break
            except Exception:
                pass

        assert resolved_feature_id is None
        db.disconnect()
